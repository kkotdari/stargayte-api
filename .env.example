# 이 파일을 .env 로 복사한 뒤 값을 채워서 사용하세요.
ENVIRONMENT=development
DEBUG=true

# SQLAlchemy DB URL. 드라이버만 바꾸면 다른 DB로 손쉽게 교체할 수 있습니다.
# 실제 계정 정보는 여기(예시 파일)에 적지 말고, 복사해서 만든 .env(gitignore 처리됨)에만
# 넣으세요. 운영 서버에서는 .env 대신 실제 환경변수로 주입합니다.
#   PostgreSQL(운영/기본): postgresql+asyncpg://<user>:<password>@localhost:5432/stargayte
#   SQLite(로컬 테스트):   sqlite+aiosqlite:///./var/stargayte.db
DATABASE_URL=
DB_ECHO=false

# 운영에서는 반드시 무작위 문자열로 교체하세요.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
# 액세스 토큰은 짧게(1시간), 만료되면 리프레시 토큰(30일, 로테이션)으로 재로그인 없이 갱신합니다.
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# 프론트엔드(Vite dev 서버) origin. 콤마로 여러 개 지정 가능.
CORS_ALLOW_ORIGINS=http://localhost:5173

STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=var/uploads
STORAGE_URL_PATH=/uploads
# 프론트가 이미지를 바로 로드할 수 있도록 절대 URL을 만드는 데 쓰는 API 서버의 공개 origin
PUBLIC_BASE_URL=http://localhost:8000
